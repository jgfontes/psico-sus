    {
      "name": "4. Queue Service (8081)",
      "description": "The patient-facing waiting queue.",
      "item": [
        {
          "name": "Join Queue",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{patientToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientName\": \"Maria Teste\",\n  \"symptomsDescription\": \"Feeling anxious and overwhelmed\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{queueUrl}}/queue/join",
              "host": ["{{queueUrl}}"],
              "path": ["queue", "join"]
            },
            "description": "hasRole('PATIENT'). patientId is read from the token's subject claim on purpose, not from the body - run '1. Auth Service / Patient Session' first."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.code === 201);",
                  "pm.collectionVariables.set('queueEntryId', pm.response.json().queueEntryId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Queue Position",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{patientToken}}" }] },
            "url": {
              "raw": "{{queueUrl}}/queue/position/{{patientId}}",
              "host": ["{{queueUrl}}"],
              "path": ["queue", "position", "{{patientId}}"]
            },
            "description": "hasRole('PATIENT') and must be your own patientId, enforced server-side."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        },
        {
          "name": "Get Queue Size",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{patientToken}}" }] },
            "url": {
              "raw": "{{queueUrl}}/queue/size",
              "host": ["{{queueUrl}}"],
              "path": ["queue", "size"]
            },
            "description": "No @PreAuthorize role restriction, but still requires any valid Bearer token (SecurityConfig defaults to authenticated())."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        },
        {
          "name": "Leave Queue",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{patientToken}}" }] },
            "url": {
              "raw": "{{queueUrl}}/queue/leave/{{patientId}}",
              "host": ["{{queueUrl}}"],
              "path": ["queue", "leave", "{{patientId}}"]
            },
            "description": "hasRole('PATIENT'), own patientId only. NOTE: this is an alternative end to the flow - only run it if you want to test leaving the queue instead of continuing to the session flow below (a session already picks the entry up out of WAITING)."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 204', () => pm.response.code === 204);"] }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Session Service (8083)",
      "description": "Starts, tracks and ends the video sessions between patient and student.",
      "item": [
        {
          "name": "Start Session (internal)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{serviceToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"queueEntryId\": \"{{queueEntryId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{sessionUrl}}/session/start",
              "host": ["{{sessionUrl}}"],
              "path": ["session", "start"]
            },
            "description": "hasRole('SERVICE') only - normally triggered by availability-service after consuming patient.joined.queue, never called directly by a client. Uses a minted SERVICE token. Make sure a student status was set to AVAILABLE first."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": ["pm.collectionVariables.set('serviceToken', mintServiceToken());"] }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.code === 201);",
                  "pm.collectionVariables.set('sessionId', pm.response.json().sessionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Confirm Session Start",
          "request": {
            "method": "PATCH",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] },
            "url": {
              "raw": "{{sessionUrl}}/session/{{sessionId}}/confirm-start",
              "host": ["{{sessionUrl}}"],
              "path": ["session", "{{sessionId}}", "confirm-start"]
            },
            "description": "hasRole('STUDENT'). Called when the student actually enters the Jitsi room."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        },
        {
          "name": "Get Session by Id",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] },
            "url": {
              "raw": "{{sessionUrl}}/session/{{sessionId}}",
              "host": ["{{sessionUrl}}"],
              "path": ["session", "{{sessionId}}"]
            },
            "description": "No @PreAuthorize role restriction, but still requires any valid Bearer token."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        },
        {
          "name": "Get Active Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{supervisorToken}}" }] },
            "url": {
              "raw": "{{sessionUrl}}/session/active",
              "host": ["{{sessionUrl}}"],
              "path": ["session", "active"]
            },
            "description": "hasAnyRole('SUPERVISOR','SERVICE')."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        },
        {
          "name": "End Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endedBy\": \"{{studentId}}\",\n  \"clinicalSummary\": \"Patient presented with acute anxiety symptoms; provided grounding techniques and safety planning.\",\n  \"icd10\": \"F41.1\",\n  \"referral\": \"Follow-up with CAPS unit recommended\",\n  \"suggestedReturn\": \"2026-07-15\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{sessionUrl}}/session/{{sessionId}}/end",
              "host": ["{{sessionUrl}}"],
              "path": ["session", "{{sessionId}}", "end"]
            },
            "description": "hasRole('STUDENT'). Publishes session.ended to RabbitMQ, consumed asynchronously by medical-record-service and availability-service - give it a moment before querying the medical record below."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        }
      ]
    },
    {
      "name": "6. Medical Record Service (8085)",
      "description": "Consumes session.ended events; also exposes read/validate endpoints. Populated asynchronously, so run these a few seconds after '5. Session Service / End Session'.",
      "item": [
        {
          "name": "Get Patient Record",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{patientToken}}" }] },
            "url": {
              "raw": "{{medicalRecordUrl}}/medical-record/patient/{{patientId}}",
              "host": ["{{medicalRecordUrl}}"],
              "path": ["medical-record", "patient", "{{patientId}}"]
            },
            "description": "Any authenticated role can call this endpoint (no @PreAuthorize); a PATIENT token is restricted server-side to its own patientId."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        },
        {
          "name": "Get Internship Hours by Student",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] },
            "url": {
              "raw": "{{medicalRecordUrl}}/medical-record/internship-hours/student/{{studentId}}",
              "host": ["{{medicalRecordUrl}}"],
              "path": ["medical-record", "internship-hours", "student", "{{studentId}}"]
            },
            "description": "hasAnyRole('STUDENT','SUPERVISOR'). NOTE: the response only exposes sessionId per record, not the internshipHoursId needed by the 'Validate' request below - you'll need to look that id up directly in medical_record.internship_hours until the API exposes it."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        },
        {
          "name": "Validate Internship Hours",
          "request": {
            "method": "PATCH",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{supervisorToken}}" }] },
            "url": {
              "raw": "{{medicalRecordUrl}}/medical-record/internship-hours/{{internshipHoursId}}/validate",
              "host": ["{{medicalRecordUrl}}"],
              "path": ["medical-record", "internship-hours", "{{internshipHoursId}}", "validate"]
            },
            "description": "hasRole('SUPERVISOR'). Fill in {{internshipHoursId}} manually (see note on 'Get Internship Hours by Student') before running this."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200', () => pm.response.code === 200);"] }
            }
          ]
        }
      ]
    }
  ]
}
