  "item": [
    {
      "name": "1. Auth Service (8080)",
      "description": "Issues Bearer tokens. Only /auth/register, /auth/login and /auth/patient-session are unauthenticated. Every credential registered here needs a referenceId that already exists in availability-service or supervision-service, so run the matching request in those folders first.",
      "item": [
        {
          "name": "Register Credentials - University",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cpf\": \"{{universityCpf}}\",\n  \"password\": \"{{universityPassword}}\",\n  \"role\": \"UNIVERSITY\",\n  \"referenceId\": \"{{universityId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{authUrl}}/auth/register",
              "host": ["{{authUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Run '1. Availability Service / Register University' first so {{universityId}} is populated."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": ["ensureVar('universityCpf', () => randomDigits(11));"] }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 201', () => pm.response.code === 201);"]
              }
            }
          ]
        },
        {
          "name": "Login - University",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cpf\": \"{{universityCpf}}\",\n  \"password\": \"{{universityPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{authUrl}}/auth/login",
              "host": ["{{authUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.code === 200);",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('universityToken', json.accessToken);"
                ]
              }
            }
          ]
