{
  "info": {
    "_postman_id": "d3f4a2e0-9b1a-4b3a-9c1a-psicosus-collection",
    "name": "PsicoSUS Microservices",
    "description": "End-to-end collection for all 6 PsicoSUS microservices (auth, availability, queue, session, supervision, medical-record). Pair with the 'PsicoSUS - Local (Docker Compose)' environment. See README.md in this folder for the recommended run order and notes on the SERVICE-role token trick used for internal-only endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Shared helpers available to every request's own pre-request script.",
          "function randomDigits(n) {",
          "    let s = '';",
          "    for (let i = 0; i < n; i++) s += Math.floor(Math.random() * 10);",
          "    return s;",
          "}",
          "",
          "function ensureVar(name, generator) {",
          "    if (!pm.collectionVariables.get(name)) {",
          "        pm.collectionVariables.set(name, generator());",
          "    }",
          "}",
          "",
          "function base64url(wordArray) {",
          "    return CryptoJS.enc.Base64.stringify(wordArray)",
          "        .replace(/=+$/, '')",
          "        .replace(/\\+/g, '-')",
          "        .replace(/\\//g, '_');",
          "}",
          "",
          "// Mints a short-lived SERVICE-role JWT the same way session-service's/availability-service's",
          "// InternalTokenService does: HS256, signing key = SHA-256(JWT_SECRET). Only valid against a",
          "// stack actually running with {{jwtSecret}} as JWT_SECRET. Used for the handful of endpoints",
          "// that are only ever called machine-to-machine (hasRole('SERVICE')), which have no public way",
          "// to obtain a token otherwise.",
          "function mintServiceToken() {",
          "    const secret = pm.collectionVariables.get('jwtSecret') || 'local-dev-secret-change-me';",
          "    const header = { alg: 'HS256', typ: 'JWT' };",
          "    const now = Math.floor(Date.now() / 1000);",
          "    const payload = { iss: 'postman', sub: 'postman-internal', role: 'SERVICE', iat: now, exp: now + 60 };",
          "",
          "    const encodedHeader = base64url(CryptoJS.enc.Utf8.parse(JSON.stringify(header)));",
          "    const encodedPayload = base64url(CryptoJS.enc.Utf8.parse(JSON.stringify(payload)));",
          "    const signingInput = encodedHeader + '.' + encodedPayload;",
          "",
          "    const key = CryptoJS.SHA256(secret);",
          "    const signature = base64url(CryptoJS.HmacSHA256(signingInput, key));",
          "",
          "    return signingInput + '.' + signature;",
          "}"
        ]
      }
    }
  ],
