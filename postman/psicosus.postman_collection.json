              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": ["pm.collectionVariables.set('serviceToken', mintServiceToken());"] }
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status is 200 or 404', () => [200, 404].includes(pm.response.code));"] }
            }
          ]
        },
